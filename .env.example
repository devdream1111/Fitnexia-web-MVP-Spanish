# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it is listed in `.gitignore`.

# API base URL (staging or production)
NEXT_PUBLIC_API_URL=https://your-api-host/fitnexia-api/v1

# App URL used for OAuth redirects (local dev or deployed origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — Web application client (Google Cloud Console)
# Client ID is safe to expose in the browser; secret must stay server-side only.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
